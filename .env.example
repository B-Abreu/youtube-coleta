# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://sua-instancia.evolution-api.com
EVOLUTION_API_KEY=cole-sua-apikey-aqui
EVOLUTION_INSTANCE=nome-da-instancia
EVOLUTION_TO_NUMBER=5511999999999

# OpenAI - para gerar o resumo HTML
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# YouTube Data API v3 - para listar uploads do canal (RSS eh bloqueado em IPs cloud)
# Criar em console.cloud.google.com -> APIs -> YouTube Data API v3 -> Credentials -> API Key
YOUTUBE_API_KEY=AIza...

# NocoDB - storage de estado e conteudo
NOCODB_URL=https://ndb.construtoracivil.com.br
NOCODB_API_KEY=cole-sua-apikey-aqui
NOCODB_TABLE_VIDEOS=mjmo0mjc6pq5zq3

# Comportamento
MAX_VIDEOS_POR_EXECUCAO=5
LEGENDA_IDIOMA_PREFERIDO=pt
# 1 = tambem grava transcricao.md e resumo.html em data/<canal>/...
# 0 = guarda tudo so no NocoDB (recomendado em routines)
SALVAR_ARQUIVOS_LOCAL=0
